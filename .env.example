TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_MODE=polling

QBIT_BASE_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
# 可选：如果 qBittorrent 提供 Bearer API token，会优先使用 token；失败时回退账号密码。
QBIT_API_TOKEN=
QBIT_REQUEST_TIMEOUT_SECONDS=20

BOT_LOG_LEVEL=INFO
JAV_CATEGORY_NAME=JAV
# 默认内置常见番号识别规则；只有需要自定义匹配时再取消注释覆盖。
# JAV_NAME_REGEX=[A-Za-z]{2,}-\\d{2,}
JAV_LARGE_FILE_THRESHOLD_GB=1
JAV_FILE_POLL_ATTEMPTS=10
JAV_FILE_POLL_INTERVAL_SECONDS=1
MAGNET_UPLOAD_LIMIT_KIB=30
STATE_FILE_PATH=data/bot_state.sqlite3
JELLYFIN_BASE_URL=http://jellyfin.local:8096
JELLYFIN_PUBLIC_BASE_URL=http://jellyfin.local:8096
JELLYFIN_API_KEY=your_jellyfin_api_key
JELLYFIN_REQUEST_TIMEOUT_SECONDS=20
JELLYFIN_DUPLICATE_DELETE_ENABLED=false
JELLYFIN_DUPLICATE_GRACE_HOURS=3

STASH_BASE_URL=http://192.168.50.46:9999
STASH_API_KEY=
STASH_REQUEST_TIMEOUT_SECONDS=20

ADD_CONTEXT_POLL_ATTEMPTS=20
ADD_CONTEXT_POLL_INTERVAL_SECONDS=1
WATCHDOG_ENABLED=true
WATCHDOG_INTERVAL_SECONDS=300
WATCHDOG_MAX_FAILURES=3
TELEGRAM_CONNECT_TIMEOUT_SECONDS=5
TELEGRAM_READ_TIMEOUT_SECONDS=8
TELEGRAM_WRITE_TIMEOUT_SECONDS=8
TELEGRAM_POOL_TIMEOUT_SECONDS=2
TELEGRAM_CONNECTION_POOL_SIZE=8
TELEGRAM_CONCURRENT_UPDATES=4
TELEGRAM_NETWORK_ERROR_RESTART_THRESHOLD=3
TELEGRAM_NETWORK_ERROR_WINDOW_SECONDS=180

# Webhook 模式需要 Cloudflare Tunnel 或其他 HTTPS 入口
WEBHOOK_BASE_URL=https://qbit-bot.example.com
WEBHOOK_LISTEN_HOST=127.0.0.1
WEBHOOK_LISTEN_PORT=8099
WEBHOOK_PATH=telegram/replace_with_random_secret
WEBHOOK_SECRET_TOKEN=replace_with_at_least_16_random_chars
WEBHOOK_BOOTSTRAP_RETRIES=3

# 如果宿主机访问 Telegram 需要代理，可取消注释
# HTTP_PROXY=http://proxy.local:8080
# HTTPS_PROXY=http://proxy.local:8080
# NO_PROXY=127.0.0.1,localhost,qbittorrent.local
